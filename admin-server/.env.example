# Admin Server Environment Configuration
# Copy this file to .env and update values for your environment

# Server
NODE_ENV=development
PORT=3001

# Database
DB_PATH=./admin.db

# JWT Secrets (MUST be set in production - use strong random strings)
JWT_SECRET=change-me-to-a-strong-random-string
H5_JWT_SECRET=change-me-to-another-strong-random-string

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Seed admin password (used by seed.js)
SEED_ADMIN_PWD=demo

# Pragmatic Play (PP) Integration - ZFPP Test Environment
PP_API_URL=https://api.prerelease-env.biz
PP_SECURE_LOGIN=your_secure_login
PP_SECRET=your_secret_key
PP_PROVIDER_ID=your_provider_id
PP_STYLENAME=your_stylename
PP_CURRENCY=USDT
PP_LOBBY_URL=https://your-site.com/#/home
PP_CASHIER_URL=https://your-site.com/#/deposit
