# Admin Server Environment Configuration
# Copy this file to .env and update values for your environment

# Server
NODE_ENV=development
PORT=3001

# Database
DB_PATH=./admin.db

# JWT Secrets (MUST be set in production - use strong random strings)
ADMIN_JWT_SECRET=change-me-to-a-strong-random-string
H5_JWT_SECRET=change-me-to-another-strong-random-string

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Seed admin password (used by seed.js)
SEED_ADMIN_PWD=demo
