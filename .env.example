# H5 Frontend Environment Configuration
# Copy this file to .env and update values for your environment

# API Base URL
VITE_API_BASE_URL=http://localhost:3001/api

# ==================== Deployment (docker-compose) ====================
# JWT Secrets (REQUIRED - no fallback allowed)
H5_JWT_SECRET=change-me-to-a-strong-random-string

# Pragmatic Play API (REQUIRED for game launch)
PP_API_URL=https://api.prerelease-env.biz
PP_SECURE_LOGIN=your_secure_login
PP_SECRET=your_secret_key
